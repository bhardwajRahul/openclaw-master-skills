      "(?i)(?:verify|confirm|validate|prove)\\s+(?:your\\s+)?(?:identity|ownership|credentials|account)\\s+by\\s+(?:sending|sharing|entering|providing|typing|pasting|running)",
      "(?i)(?:scan|check)\\s+this\\s+(?:QR|qr)\\s+code\\s+(?:to|for|with)\\s+(?:verify|confirm|connect|login|authenticate|authorize|complete)",
      "(?i)(?:don't|do\\s+not)\\s+(?:tell|show|share|mention|reveal)\\s+(?:this|these|the)\\s+(?:to\\s+)?(?:anyone|others|your\\s+(?:team|admin|manager|supervisor|boss))",
      "(?i)(?:keep|this\\s+is)\\s+(?:this\\s+)?(?:between\\s+us|a\\s+secret|confidential|private|off\\s+the\\s+record)",
      "(?i)(?:i\\s+(?:just\\s+)?need|can\\s+you\\s+(?:just\\s+)?(?:quickly|briefly))\\s+(?:your|the)\\s+(?:api\\s*key|token|password|credentials|private\\s*key|secret|mnemonic|seed\\s*phrase)",
      "(?i)(?:for\\s+)?(?:verification|debugging|testing|troubleshooting|support)\\s+(?:purposes?)?\\s*,?\\s*(?:please\\s+)?(?:share|send|provide|paste|enter|type)\\s+(?:your\\s+)?(?:api\\s*key|token|password|credentials|private\\s*key|secret)"
    ]
  },

  "secret_patterns_crypto": {
    "_description": "Crypto-specific secret patterns — exchange API keys, wallet formats, DeFi tokens",
    "severity": "CRITICAL",
    "patterns": [
      "(?i)(?:binance|bnb).*(?:api|secret)\\s*(?:key)?\\s*[:=]\\s*[A-Za-z0-9]{20,}",
      "(?i)(?:coinbase).*(?:api|secret)\\s*(?:key)?\\s*[:=]\\s*[A-Za-z0-9+/=]{20,}",
      "(?i)(?:kraken).*(?:api|secret|private)\\s*(?:key)?\\s*[:=]\\s*[A-Za-z0-9+/=]{20,}",
      "(?i)(?:ftx|bybit|okx|kucoin|huobi|gate\\.?io|bitfinex|bitstamp|gemini|crypto\\.com).*(?:api|secret)\\s*(?:key)?\\s*[:=]\\s*[A-Za-z0-9+/=-]{16,}",
      "(?i)(?:etherscan|bscscan|polygonscan|arbiscan|snowtrace).*(?:api)\\s*(?:key)?\\s*[:=]\\s*[A-Za-z0-9]{20,}",
      "(?i)(?:infura|alchemy|moralis|quicknode|chainstack|ankr).*(?:api|project|app)\\s*(?:key|id|secret)?\\s*[:=]\\s*[A-Za-z0-9_-]{16,}",
      "(?i)(?:metamask|phantom|rabby|trust\\s*wallet).*(?:private|secret|mnemonic|seed)",
      "(?i)(?:ledger|trezor).*(?:recovery|mnemonic|seed|backup)\\s*(?:phrase)?\\s*[:=]",
      "xprv[A-Za-z0-9]{107}",
      "xpub[A-Za-z0-9]{107}",
      "(?:L|K|5)[1-9A-HJ-NP-Za-km-z]{50,51}",
      "bc1[a-zA-HJ-NP-Z0-9]{39,59}",
      "(?:1|3)[1-9A-HJ-NP-Za-km-z]{25,34}",
      "0x[0-9a-fA-F]{40}",
      "[1-9A-HJ-NP-Za-km-z]{32,44}",
      "T[1-9A-HJ-NP-Za-km-z]{33}",
      "(?:cosmos|osmo|juno|stars|sei)[1-9a-z]{38,}",
      "terra1[a-z0-9]{38}",
      "(?i)(?:private_key|privkey|secret_key|priv_key)\\s*[:=]\\s*(?:0x)?[0-9a-fA-F]{64}",
      "(?i)(?:mnemonic|seed_phrase|recovery_phrase|backup_phrase)\\s*[:=]\\s*['\"]?[a-z]+(?:\\s+[a-z]+){11,23}['\"]?"
    ]
  },

  "secret_patterns_saas": {
    "_description": "SaaS and cloud service API key patterns",
    "severity": "CRITICAL",
    "patterns": [
      "(?i)sk-proj-[A-Za-z0-9_-]{20,}",
      "(?i)sk-ant-(?:api03|sid01)-[A-Za-z0-9_-]{20,}",
      "(?i)(?:AKIA|ASIA)[A-Z0-9]{16}",
      "AIza[A-Za-z0-9_\\-]{35}",
      "(?i)(?:sk|rk|pk)_(?:live|test)_[A-Za-z0-9]{20,}",
      "(?i)(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36,}",
      "(?i)(?:glpat|gldt|glrt|glsoat)-[A-Za-z0-9_-]{20,}",
      "(?i)[0-9]{8,10}:[A-Za-z0-9_-]{35}",
      "(?i)xox[bpsa]-[A-Za-z0-9-]{10,}",
      "(?i)(?:sq0[a-z]{3})-[A-Za-z0-9_-]{22,}",
      "(?i)(?:EAAG|EAAa)[A-Za-z0-9]+",
      "(?i)(?:shpat|shpca|shppa|shpss)_[A-Za-z0-9]{32,}",
      "(?i)key-[A-Za-z0-9]{24,}",
      "(?i)(?:twilio|TWILIO).*(?:SK|AC)[a-z0-9]{32}",
      "(?i)SG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}",
      "(?i)(?:mailgun|mg).*key-[A-Za-z0-9]{32,}",
      "(?i)hf_[A-Za-z0-9]{34,}",
      "(?i)r8_[A-Za-z0-9]{34,}",
      "(?i)(?:eyJ)[A-Za-z0-9_-]{10,}\\.(?:eyJ)[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]+",
      "(?i)(?:postgres|mysql|mongodb|redis|amqp|rediss?)://[^\\s'\"]{10,}",
      "(?i)-----BEGIN (?:RSA |EC |OPENSSH |DSA |ENCRYPTED )?PRIVATE KEY-----",
      "(?i)(?:bearer|token|authorization)\\s+[A-Za-z0-9_\\-\\.]{20,}"
    ]
  },

  "metadata_ssrf": {
    "_description": "Cloud metadata and internal network SSRF targets",
    "severity": "CRITICAL",
    "patterns": [
      "(?:169\\.254\\.169\\.254|metadata\\.google\\.internal|100\\.100\\.100\\.200)",
      "(?:fd00:ec2::254|\\[fd00:ec2::254\\])",
      "(?i)(?:http://)?169\\.254\\.170\\.2/",
      "(?i)(?:http://)?(?:metadata|instance-data)\\.(?:internal|ec2|cloud)",
      "(?i)/latest/meta-data/",
      "(?i)/latest/user-data/",
      "(?i)/latest/api/token",
      "(?i)/computeMetadata/v1/",
      "(?i)/metadata/instance\\?",
      "(?i)/metadata/v1/",
      "(?i)(?:http://)?localhost(?::[0-9]+)?/(?:admin|config|env|debug|status|metrics|health|info|trace|dump|internal|manage|actuator)",
      "(?i)(?:http://)?127\\.0\\.0\\.1(?::[0-9]+)?/(?:admin|config|env|debug|status|metrics|info|internal)",
      "(?i)(?:http://)?\\[::1\\](?::[0-9]+)?/",
      "(?i)(?:http://)?0\\.0\\.0\\.0(?::[0-9]+)?/",
      "(?i)(?:http://)?10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}",
      "(?i)(?:http://)?172\\.(?:1[6-9]|2[0-9]|3[01])\\.[0-9]{1,3}\\.[0-9]{1,3}",
      "(?i)(?:http://)?192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}",
      "(?i)\\.(?:internal|local|localhost|corp|intranet|private)(:[0-9]+)?/"
    ]
  },

  "encoding_evasion": {
    "_description": "Encoding tricks used to bypass pattern matching",
    "severity": "HIGH",
    "patterns": [
      "(?i)\\\\u[0-9a-f]{4}.*(?:ignore|system|prompt|instructions|override|bypass|disable)",
      "(?i)&#(?:x[0-9a-f]+|[0-9]+);.*(?:ignore|system|prompt|override)",
      "(?i)%[0-9a-f]{2}%[0-9a-f]{2}.*(?:ignore|system|prompt)",
      "(?i)(?:eval|exec|decode|unescape|fromCharCode|atob|Buffer\\.from)\\s*\\(",
      "(?i)String\\.fromCharCode\\s*\\(",
      "(?i)\\\\x[0-9a-f]{2}(?:\\\\x[0-9a-f]{2}){3,}",
      "(?i)(?:rot13|caesar|base32|base58|base85|xxencode|uuencode)",
      "(?i)char\\s*\\(\\s*[0-9]+\\s*(?:,\\s*[0-9]+\\s*){3,}\\)",
      "(?i)concat\\s*\\(\\s*['\"][^'\"]{1,3}['\"]\\s*(?:,\\s*['\"][^'\"]{1,3}['\"]\\s*){3,}\\)"
    ]
  },

  "file_system_attacks": {
    "_description": "Path traversal and filesystem manipulation patterns",
    "severity": "HIGH",
    "patterns": [
      "(?i)\\.\\./\\.\\./",
      "(?i)\\.\\.\\\\\\.\\.\\\\",
      "(?i)%2e%2e(?:%2f|%5c)",
      "(?i)\\.\\.%252f",
