      "(?i)~/.(?:ssh|gnupg|aws|gcloud|azure|kube|docker|config|env|bashrc|zshrc|profile|netrc|npmrc|pypirc)",
      "(?i)/(?:proc|sys|dev)/",
      "(?i)(?:C:|\\\\\\\\)(?:Windows|Users|Program)",
      "(?i)%USERPROFILE%",
      "(?i)%APPDATA%",
      "(?i)\\.(?:git|svn|hg)/(?:config|credentials|HEAD)",
      "(?i)\\bfind\\b.*-exec\\b",
      "(?i)\\bsymlink\\b|\\bln\\s+-s\\b",
